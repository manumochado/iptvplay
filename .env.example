# Copia este archivo a .env en la raíz del repo, o a server/.env
# URL base del panel Xtream (sin barra final).
# En muchos servicios el puerto 8080 es HTTP, no HTTPS: usa http://…:8080
IPTV_BASE_URL=http://ejemplo.com:8080
IPTV_USERNAME=tu_usuario
IPTV_PASSWORD=tu_contraseña
# Solo si el certificado SSL da problemas (no lo actives sin necesidad):
# IPTV_TLS_INSECURE=1
# Railway / hosting: forzar IPv4 al panel (por defecto activo). Desactivar: IPTV_IPV4=0
# IPTV_IPV4=0
# Timeouts ms (opcional): IPTV_CONNECT_TIMEOUT_MS=60000  IPTV_BODY_TIMEOUT_MS=120000
# Logs de depuracion de auth (solo temporal):
# IPTV_DEBUG_AUTH=1
# Para ver usuario/clave completos en logs (riesgo, usar solo minutos):
# IPTV_LOG_SECRETS=1
